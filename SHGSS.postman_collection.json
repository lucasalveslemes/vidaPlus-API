                  "});\r",
                  "\r",
                  "pm.test(\"Paciente retornado com ID\", function () {\r",
                  "    var json = pm.response.json();\r",
                  "    pm.expect(json.id).to.be.a(\"number\");\r",
                  "    pm.expect(json.id).to.be.above(0);\r",
